APP_NAME="MoniWis Sushi"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://tu-app.onrender.com

APP_LOCALE=es
APP_FALLBACK_LOCALE=es
APP_FAKER_LOCALE=es_CL

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stderr
LOG_LEVEL=error

# ─── BASE DE DATOS ───────────────────────────────────────────────
# Opción A: Render MySQL (plan pagado)
# DB_CONNECTION=mysql
# DB_HOST=<render-host>
# DB_PORT=3306
# DB_DATABASE=<db-name>
# DB_USERNAME=<user>
# DB_PASSWORD=<password>

# Opción B: PlanetScale (gratis)
# DB_CONNECTION=mysql
# DB_HOST=aws.connect.psdb.cloud
# DB_PORT=3306
# DB_DATABASE=moniwis-sushi
# DB_USERNAME=<planetscale-user>
# DB_PASSWORD=<planetscale-password>
# MYSQL_ATTR_SSL_CA=/etc/ssl/certs/ca-certificates.crt

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=sushi_db
DB_USERNAME=root
DB_PASSWORD=

# ─── SESIONES / CACHÉ / COLAS ────────────────────────────────────
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database
CACHE_STORE=database

# ─── WHATSAPP ────────────────────────────────────────────────────
# Número sin espacios ni guiones, incluye código de país
# Ej: Chile = 56912345678 | Argentina = 5491112345678
WHATSAPP_NUMBER=56900000000

# ─── MAIL (opcional) ─────────────────────────────────────────────
MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="contacto@moniwissushi.cl"
MAIL_FROM_NAME="${APP_NAME}"

VITE_APP_NAME="${APP_NAME}"
